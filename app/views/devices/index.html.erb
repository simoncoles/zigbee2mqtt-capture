<div class="w-full max-w-7xl mx-auto">
  <div class="mb-8">
    <h1 class="text-4xl font-bold text-gray-900 mb-2">Devices</h1>
    <p class="text-gray-600">All Zigbee devices discovered on your network</p>
  </div>

  <%= render "shared/search_bar", url: devices_path, placeholder: "Search by name, IEEE address, manufacturer, or model..." %>

  <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-200 bg-gray-50">
      <div class="flex items-center justify-between">
        <h2 class="text-xl font-semibold text-gray-900">Devices</h2>
        <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-blue-100 text-blue-800">
          <%= @pagy.count %> total
        </span>
      </div>
    </div>

    <div class="p-6">
      <% if @devices.any? %>
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-200">
            <thead>
              <tr>
                <th class="px-3 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Name</th>
                <th class="px-3 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">IEEE Address</th>
                <th class="px-3 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Manufacturer</th>
                <th class="px-3 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Model</th>
                <th class="px-3 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Power Source</th>
                <th class="px-3 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Last Heard</th>
                <th class="px-3 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
              </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
              <% @devices.each do |device| %>
                <tr class="hover:bg-gray-50 transition-colors duration-150">
                  <td class="px-3 py-4 whitespace-nowrap text-sm font-medium">
                    <%= link_to device.friendly_name || device.ieee_addr,
                        device_monitoring_path(device),
                        class: "text-blue-600 hover:text-blue-800" %>
                  </td>
                  <td class="px-3 py-4 whitespace-nowrap text-sm text-gray-500 font-mono"><%= device.ieee_addr %></td>
                  <td class="px-3 py-4 whitespace-nowrap text-sm text-gray-900"><%= device.manufacturer_name %></td>
                  <td class="px-3 py-4 whitespace-nowrap text-sm text-gray-500"><%= device.model %></td>
                  <td class="px-3 py-4 whitespace-nowrap text-sm text-gray-500"><%= device.power_source %></td>
                  <td class="px-3 py-4 whitespace-nowrap text-sm text-gray-500">
                    <% if device.last_heard_from %>
                      <%= time_ago_in_words(device.last_heard_from) %> ago
                    <% else %>
                      <span class="text-gray-400">Never</span>
                    <% end %>
                  </td>
                  <td class="px-3 py-4 whitespace-nowrap text-sm">
                    <% status = device.monitoring_status %>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
                      <%= case status
                          when 'Responsive' then 'bg-green-100 text-green-800'
                          when 'Non-Responsive' then 'bg-amber-100 text-amber-800'
                          else 'bg-gray-100 text-gray-800'
                          end %>">
                      <%= status %>
                    </span>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <p class="text-sm text-gray-500">No devices found<%= " matching '#{params[:q]}'" if params[:q].present? %>.</p>
      <% end %>
    </div>

    <%= render "shared/pagination", pagy: @pagy %>
  </div>

  <div class="mt-6">
    <%= link_to root_path, class: "inline-flex items-center text-sm font-medium text-blue-600 hover:text-blue-800" do %>
      <span class="mr-1">&larr;</span> Back to Dashboard
    <% end %>
  </div>
</div>
