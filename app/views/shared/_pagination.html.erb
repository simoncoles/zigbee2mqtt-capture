<% if pagy.pages > 1 %>
  <div class="flex items-center justify-between px-6 py-4 border-t border-gray-200">
    <div class="text-sm text-gray-500">
      Showing <%= pagy.from %> to <%= pagy.to %> of <%= pagy.count %> results
    </div>
    <div class="flex gap-2">
      <% if pagy.previous %>
        <%= link_to "Previous", url_for(request.query_parameters.merge(page: pagy.previous)),
            class: "inline-flex items-center px-3 py-1 border border-gray-300 rounded-md text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 transition-colors duration-150" %>
      <% end %>
      <span class="inline-flex items-center px-3 py-1 text-sm text-gray-500">
        Page <%= pagy.page %> of <%= pagy.pages %>
      </span>
      <% if pagy.next %>
        <%= link_to "Next", url_for(request.query_parameters.merge(page: pagy.next)),
            class: "inline-flex items-center px-3 py-1 border border-gray-300 rounded-md text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 transition-colors duration-150" %>
      <% end %>
    </div>
  </div>
<% elsif pagy.count > 0 %>
  <div class="px-6 py-4 border-t border-gray-200">
    <div class="text-sm text-gray-500">
      Showing all <%= pagy.count %> results
    </div>
  </div>
<% end %>
