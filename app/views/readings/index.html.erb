<div class="w-full max-w-7xl mx-auto">
  <div class="mb-8">
    <h1 class="text-4xl font-bold text-gray-900 mb-2">Sensor Readings</h1>
    <p class="text-gray-600">All sensor readings captured from your Zigbee devices</p>
  </div>

  <%= render "shared/search_bar", url: readings_path, placeholder: "Search by device name, sensor key, or value..." %>

  <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-200 bg-gray-50">
      <div class="flex items-center justify-between">
        <h2 class="text-xl font-semibold text-gray-900">Readings</h2>
        <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-blue-100 text-blue-800">
          <%= @pagy.count %> total
        </span>
      </div>
    </div>

    <div class="p-6">
      <% if @readings.any? %>
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-200">
            <thead>
              <tr>
                <th class="px-3 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Device</th>
                <th class="px-3 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Sensor Key</th>
                <th class="px-3 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Value</th>
                <th class="px-3 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Time</th>
              </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
              <% @readings.each do |reading| %>
                <tr class="hover:bg-gray-50 transition-colors duration-150">
                  <td class="px-3 py-4 whitespace-nowrap text-sm">
                    <% if reading.device %>
                      <%= link_to reading.device.friendly_name || reading.device.ieee_addr,
                          device_monitoring_path(reading.device),
                          class: "text-blue-600 hover:text-blue-800" %>
                    <% else %>
                      <span class="text-gray-400">Unknown</span>
                    <% end %>
                  </td>
                  <td class="px-3 py-4 whitespace-nowrap">
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-indigo-100 text-indigo-800">
                      <%= reading.key %>
                    </span>
                  </td>
                  <td class="px-3 py-4 whitespace-nowrap text-sm text-gray-900"><%= reading.value %></td>
                  <td class="px-3 py-4 whitespace-nowrap text-sm text-gray-500"><%= time_ago_in_words(reading.created_at) %> ago</td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <p class="text-sm text-gray-500">No readings found<%= " matching '#{params[:q]}'" if params[:q].present? %>.</p>
      <% end %>
    </div>

    <%= render "shared/pagination", pagy: @pagy %>
  </div>

  <div class="mt-6">
    <%= link_to root_path, class: "inline-flex items-center text-sm font-medium text-blue-600 hover:text-blue-800" do %>
      <span class="mr-1">&larr;</span> Back to Dashboard
    <% end %>
  </div>
</div>
