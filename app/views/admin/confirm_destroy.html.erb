<div class="w-full max-w-3xl mx-auto">
  <div class="mb-8">
    <h1 class="text-4xl font-bold text-red-700 mb-2">Confirm Data Deletion</h1>
    <p class="text-gray-600">This action is irreversible. Read carefully before proceeding.</p>
  </div>

  <% if flash[:alert] %>
    <div class="mb-6 bg-amber-50 border border-amber-200 text-amber-800 rounded-lg px-4 py-3">
      <%= flash[:alert] %>
    </div>
  <% end %>

  <div class="bg-red-50 border-2 border-red-300 rounded-lg p-6 mb-6">
    <h2 class="text-lg font-semibold text-red-900 mb-3">You are about to delete:</h2>
    <ul class="space-y-1 mb-4">
      <% @table_counts.each do |model, count| %>
        <li class="flex justify-between text-sm">
          <span class="font-medium text-gray-900"><%= model.name %> <span class="text-gray-500">(<%= model.table_name %>)</span></span>
          <span class="font-semibold text-red-800"><%= number_with_delimiter(count) %> record<%= "s" unless count == 1 %></span>
        </li>
      <% end %>
    </ul>
    <p class="text-sm text-red-900">
      All data listed above will be permanently removed from the database.
    </p>
  </div>

  <%= form_with url: destroy_all_admin_path, method: :post, local: true, class: "bg-white rounded-lg shadow-sm border border-gray-200 p-6" do |f| %>
    <div class="mb-4">
      <label for="confirmation" class="block text-sm font-medium text-gray-900 mb-2">
        Type <code class="px-1.5 py-0.5 bg-gray-100 rounded text-red-700 font-mono">DELETE ALL DATA</code> to confirm:
      </label>
      <%= f.text_field :confirmation,
          id: "confirmation",
          autocomplete: "off",
          class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-red-500 font-mono" %>
    </div>

    <div class="flex items-center justify-end space-x-3">
      <%= link_to "Cancel",
          admin_path,
          class: "inline-flex items-center px-4 py-2 border border-gray-300 rounded-md text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 transition-colors duration-150" %>
      <%= f.submit "Permanently Delete All Data",
          class: "inline-flex items-center px-4 py-2 border border-red-600 rounded-md text-sm font-semibold text-white bg-red-600 hover:bg-red-700 transition-colors duration-150 cursor-pointer" %>
    </div>
  <% end %>
</div>
