<div class="w-full max-w-7xl mx-auto">
  <div class="mb-8">
    <h1 class="text-4xl font-bold text-gray-900 mb-2">Command Messages</h1>
    <p class="text-gray-600">Outbound <code class="text-xs bg-gray-100 px-1 py-0.5 rounded">/set</code> commands captured from the broker</p>
  </div>

  <%= render "shared/search_bar", url: commands_mqtt_messages_path, placeholder: "Search by topic, device name, or payload..." %>

  <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-200 bg-gray-50">
      <div class="flex items-center justify-between">
        <h2 class="text-xl font-semibold text-gray-900">Commands</h2>
        <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-amber-100 text-amber-800">
          <%= @pagy.count %> total
        </span>
      </div>
    </div>

    <div class="p-6">
      <% if @mqtt_messages.any? %>
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-200">
            <thead>
              <tr>
                <%= sortable_header("Topic", "topic") %>
                <%= sortable_header("Device", "friendly_name") %>
                <th class="px-3 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Payload</th>
                <%= sortable_header("Received", "created_at") %>
              </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
              <% @mqtt_messages.each do |message| %>
                <tr class="hover:bg-gray-50 transition-colors duration-150 cursor-pointer" onclick="window.location='<%= mqtt_message_path(message) %>'">
                  <td class="px-3 py-4 text-sm text-gray-900 font-medium"><%= message.topic %></td>
                  <td class="px-3 py-4 whitespace-nowrap text-sm text-gray-900">
                    <% if message.device %>
                      <%= link_to message.friendly_name, device_monitoring_path(message.device), class: "text-blue-600 hover:text-blue-800", onclick: "event.stopPropagation();" %>
                    <% else %>
                      <%= message.friendly_name %>
                      <span class="ml-1 inline-flex items-center px-1.5 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-600" title="No matching device record">unknown</span>
                    <% end %>
                  </td>
                  <td class="px-3 py-4">
                    <code class="bg-gray-100 px-2 py-1 rounded text-xs"><%= truncate(message.content.to_s, length: 120) %></code>
                  </td>
                  <td class="px-3 py-4 whitespace-nowrap text-sm text-gray-500"><%= time_ago_in_words(message.created_at) %> ago</td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <p class="text-sm text-gray-500">No command messages found<%= " matching '#{params[:q]}'" if params[:q].present? %>.</p>
      <% end %>
    </div>

    <%= render "shared/pagination", pagy: @pagy %>
  </div>

  <div class="mt-6 flex space-x-4">
    <%= link_to mqtt_messages_path, class: "inline-flex items-center text-sm font-medium text-blue-600 hover:text-blue-800" do %>
      <span class="mr-1">&larr;</span> Device Messages
    <% end %>
    <%= link_to system_mqtt_messages_path, class: "inline-flex items-center text-sm font-medium text-blue-600 hover:text-blue-800" do %>
      <span class="mr-1">&larr;</span> System Messages
    <% end %>
    <%= link_to root_path, class: "inline-flex items-center text-sm font-medium text-blue-600 hover:text-blue-800" do %>
      <span class="mr-1">&larr;</span> Back to Dashboard
    <% end %>
  </div>
</div>
