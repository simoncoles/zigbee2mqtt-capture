<div class="w-full max-w-7xl mx-auto">
  <div class="mb-8">
    <h1 class="text-4xl font-bold text-gray-900 mb-2">Topic Details</h1>
    <p class="text-gray-600">All captured messages for this topic</p>
  </div>

  <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden mb-6">
    <div class="px-6 py-4 bg-gray-50 border-b border-gray-200">
      <h2 class="text-xl font-semibold text-gray-900">Topic Information</h2>
    </div>
    <div class="p-6">
      <dl class="space-y-4">
        <div class="flex justify-between">
          <dt class="text-sm font-medium text-gray-500">Name</dt>
          <dd class="text-sm text-gray-900"><code class="bg-gray-100 px-2 py-1 rounded"><%= @mqtt_topic.name %></code></dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-sm font-medium text-gray-500">Handled by existing code</dt>
          <dd class="text-sm">
            <% if @mqtt_topic.handled %>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">handled</span>
            <% else %>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-amber-100 text-amber-800">unhandled</span>
            <% end %>
          </dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-sm font-medium text-gray-500">Messages captured</dt>
          <dd class="text-sm text-gray-900"><%= number_with_delimiter(@mqtt_topic.message_count) %></dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-sm font-medium text-gray-500">First seen</dt>
          <dd class="text-sm text-gray-900">
            <div><%= @mqtt_topic.first_seen_at.strftime("%Y-%m-%d %H:%M:%S") %></div>
            <div class="text-xs text-gray-500"><%= time_ago_in_words(@mqtt_topic.first_seen_at) %> ago</div>
          </dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-sm font-medium text-gray-500">Last seen</dt>
          <dd class="text-sm text-gray-900">
            <div><%= @mqtt_topic.last_seen_at.strftime("%Y-%m-%d %H:%M:%S") %></div>
            <div class="text-xs text-gray-500"><%= time_ago_in_words(@mqtt_topic.last_seen_at) %> ago</div>
          </dd>
        </div>
      </dl>
    </div>
  </div>

  <%= render "shared/search_bar", url: mqtt_topic_path(@mqtt_topic), placeholder: "Search payloads..." %>

  <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-200 bg-gray-50">
      <div class="flex items-center justify-between">
        <h2 class="text-xl font-semibold text-gray-900">Messages</h2>
        <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-purple-100 text-purple-800">
          <%= @pagy.count %> total
        </span>
      </div>
    </div>

    <div class="p-6">
      <% if @raw_mqtt_messages.any? %>
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-200">
            <thead>
              <tr>
                <th class="px-3 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Payload</th>
                <%= sortable_header("Retained", "retained") %>
                <%= sortable_header("QoS", "qos") %>
                <%= sortable_header("Received", "created_at") %>
              </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
              <% @raw_mqtt_messages.each do |message| %>
                <tr class="hover:bg-gray-50 transition-colors duration-150 cursor-pointer" onclick="window.location='<%= raw_mqtt_message_path(message) %>'">
                  <td class="px-3 py-4 text-sm text-gray-700 font-mono"><%= truncate(message.payload.to_s, length: 160) %></td>
                  <td class="px-3 py-4 whitespace-nowrap text-sm">
                    <% if message.retained %>
                      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">retained</span>
                    <% else %>
                      <span class="text-gray-400 text-xs">—</span>
                    <% end %>
                  </td>
                  <td class="px-3 py-4 whitespace-nowrap text-sm text-gray-900"><%= message.qos %></td>
                  <td class="px-3 py-4 whitespace-nowrap text-sm text-gray-500"><%= time_ago_in_words(message.created_at) %> ago</td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <p class="text-sm text-gray-500">No messages found<%= " matching '#{params[:q]}'" if params[:q].present? %>.</p>
      <% end %>
    </div>

    <%= render "shared/pagination", pagy: @pagy %>
  </div>

  <div class="mt-6 flex space-x-4">
    <%= link_to mqtt_topics_path, class: "inline-flex items-center text-sm font-medium text-blue-600 hover:text-blue-800" do %>
      <span class="mr-1">&larr;</span> Back to Topics
    <% end %>
    <%= link_to raw_mqtt_messages_path, class: "inline-flex items-center text-sm font-medium text-blue-600 hover:text-blue-800" do %>
      View All Raw Messages <span class="ml-1">&rarr;</span>
    <% end %>
  </div>
</div>
