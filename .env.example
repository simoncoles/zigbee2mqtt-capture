# The URI to use to access your MQTT Broker
# The format is 
# mqtt(s)://[username[:password]@]host[:port]

MQTT_URL="mqtt://username:password@localhost:1883"

# Prune any messages older than this
PRUNE_HOURS=48

# Database connection — Postgres is required (good_job dependency).
# The dev container already runs a postgres service at host "postgres" with
# user/password "postgres"/"postgres"; the default config/database.yml picks
# that up automatically. Set DATABASE_URL here if you want to override.
# DATABASE_URL="postgresql://postgres:postgres@postgres:5432/zigbee2mqtt_capture_development"

# The base URL of your Zigbee2MQTT server, e.g. http://192.168.2.3:8080
# Note, no / at the end
ZIGBEE2MQTT_BASE="http://192.168.1.100:8080"

# Device Monitoring Configuration
# ================================

# Enable/disable monitoring globally
# Default: true
MONITOR_ENABLED=true

# How often to check devices (in seconds)
# Default: 300 (5 minutes)
MONITOR_CHECK_INTERVAL=300

# Number of devices to process in each batch
# Default: 50
MONITOR_BATCH_SIZE=50

# Enable debug logging for monitoring
# Default: false
MONITOR_DEBUG=false